# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build output and locally-installed tooling (controller-gen, kustomize,
# setup-envtest, the manager binary, etc.)
bin/
Dockerfile.cross

# Distribution artifacts from `make build-installer` / helm packaging.
# Ignore dist/ contents (not the dir itself) so the installer can be re-included.
dist/*
!dist/install.yaml
*.tgz

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Local env and cluster credentials — never commit these
.env
*.kubeconfig
kubeconfig

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.idea/
.vscode/
*.swp
*~
