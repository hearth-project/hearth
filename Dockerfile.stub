# Build the vllm-stub binary (a CPU fake of a vLLM OpenAI server, for no-GPU e2e tests)
FROM golang:1.26 AS builder
ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace
COPY go.mod go.mod
COPY go.sum go.sum
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH} go build -a -o vllm-stub ./test/vllm-stub

# Alpine (not distroless) so the image has /bin/sh: Hearth's graceful-drain renders a
# preStop hook (`/bin/sh -c "sleep <drainTimeout>"`) on the serving container, exactly as
# it would on a real vLLM image. A shell-less base would skip the hook and break drain.
FROM alpine:3.20
WORKDIR /
COPY --from=builder /workspace/vllm-stub .
USER 65532:65532

ENTRYPOINT ["/vllm-stub"]
