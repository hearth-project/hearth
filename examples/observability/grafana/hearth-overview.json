{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Hearth — LLM Serving Overview",
  "uid": "hearth-overview",
  "schemaVersion": 39,
  "editable": true,
  "tags": ["hearth", "llm", "vllm"],
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "${DS_PROMETHEUS}" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Gateway pending (queue depth)",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(hearth_gateway_pending)", "legendFormat": "pending" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate by status code",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(hearth_gateway_requests_total[5m])) by (code)", "legendFormat": "{{code}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Rejections by reason (429 / 503)",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 0 },
      "targets": [
        { "expr": "sum(rate(hearth_gateway_rejections_total[5m])) by (reason)", "legendFormat": "{{reason}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cold-start wait (p95, seconds)",
      "datasource": "${datasource}",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(hearth_gateway_activation_wait_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "vLLM requests (waiting / running)",
      "datasource": "${datasource}",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum(vllm:num_requests_waiting)", "legendFormat": "waiting" },
        { "expr": "sum(vllm:num_requests_running)", "legendFormat": "running" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "vLLM KV-cache usage (%)",
      "datasource": "${datasource}",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "targets": [
        { "expr": "avg(vllm:gpu_cache_usage_perc)", "legendFormat": "kv-cache" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "vLLM time-to-first-token (p95, seconds)",
      "datasource": "${datasource}",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    }
  ]
}
